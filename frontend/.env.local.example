# Foresight Frontend — Local Environment
# Copy this to .env.local and never commit it

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket base URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# App name
NEXT_PUBLIC_APP_NAME=Foresight

# Supabase (fill in after setup)
NEXT_PUBLIC_SUPABASE_URL=https://fvrzkwfmtbfipnlrvlwq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
