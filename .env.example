# ========================================
# Foresight — Environment Variables
# Copy this file to .env and fill in values
# ========================================

# --- Application ---
APP_NAME=Foresight
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
DEBUG=true

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Supabase (Cloud PostgreSQL) ---
# Project: fvrzkwfmtbfipnlrvlwq
# Dashboard: https://supabase.com/dashboard/project/fvrzkwfmtbfipnlrvlwq
SUPABASE_URL=https://fvrzkwfmtbfipnlrvlwq.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct PostgreSQL connection for SQLAlchemy ORM (Session Pooler — port 6543)
# Replace [YOUR-PASSWORD] with your Supabase database password
DATABASE_URL=postgresql+asyncpg://postgres.fvrzkwfmtbfipnlrvlwq:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Direct connection for migrations (port 5432)
DIRECT_DATABASE_URL=postgresql://postgres.fvrzkwfmtbfipnlrvlwq:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Connection pool (tuned for Supabase free tier)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=foresight

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=Foresight
NEXT_PUBLIC_SUPABASE_URL=https://fvrzkwfmtbfipnlrvlwq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- LLM / AI ---
GROQ_API_KEY=your-groq-api-key
HUGGINGFACE_TOKEN=your-huggingface-token
OLLAMA_BASE_URL=http://localhost:11434

# --- Monitoring ---
SENTRY_DSN=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# --- Deployment ---
RAILWAY_TOKEN=
VERCEL_TOKEN=
FLY_API_TOKEN=

# --- MCP Integrations ---
MCP_BROWSER_USE_ENABLED=true
MCP_KUBERNETES_ENABLED=false
