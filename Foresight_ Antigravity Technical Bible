        Returns:
        {
            "detection_id": int,
            "forecast_points": [
                {
                    "date": str,
                    "predicted_mentions": float,
                    "lower_bound": float,
                    "upper_bound": float
                }
            ],
            "trend_direction": str,  # up, down, stable
            "confidence": float
        }
        """
        # Prepare data for Prophet
        df = self._prepare_data(historical_data)
        
        if len(df) < 10:
            # Not enough data for forecasting
            return self._simple_forecast(detection_id, historical_data)
        
        # Train Prophet model
        model = Prophet(
            yearly_seasonality=False,
            weekly_seasonality=True,
            daily_seasonality=False,
            interval_width=0.95
        )
        
        model.fit(df)
        
        # Generate forecast for 26 weeks (182 days)
        future = model.make_future_dataframe(periods=182)
        forecast = model.predict(future)
        
        # Extract forecast points
        forecast_points = self._extract_forecast_points(forecast)
        
        # Determine trend direction
        trend_direction = self._determine_trend_direction(forecast_points)
        
        # Calculate confidence
        confidence = self._calculate_forecast_confidence(forecast)
        
        return {
            "detection_id": detection_id,
            "forecast_points": forecast_points,
            "trend_direction": trend_direction,
            "confidence": confidence,
            "generated_at": datetime.utcnow().isoformat()
        }
    
    def _prepare_data(self, historical_data: List[Dict]) -> pd.DataFrame:
        """Prepare data for Prophet."""
        # Convert to DataFrame
        df = pd.DataFrame(historical_data)
        
        # Rename columns for Prophet
        df = df.rename(columns={
            "timestamp": "ds",
            "mentions": "y"
        })
        
        # Ensure datetime format
        df["ds"] = pd.to_datetime(df["ds"])
        
        # Sort by date
        df = df.sort_values("ds")
        
        # Remove duplicates
        df = df.drop_duplicates(subset=["ds"])
        
        return df[["ds", "y"]]
    
    def _extract_forecast_points(self, forecast: pd.DataFrame) -> List[Dict]:
        """Extract forecast points from Prophet output."""
        # Get future forecasts only
        future_forecast = forecast[forecast["ds"] > datetime.utcnow()]
        
        forecast_points = []
        for _, row in future_forecast.iterrows():
            forecast_points.append({
                "date": row["ds"].isoformat(),
                "predicted_mentions": max(0, int(row["yhat"])),
                "lower_bound": max(0, int(row["yhat_lower"])),
                "upper_bound": max(0, int(row["yhat_upper"]))
            })
        
        return forecast_points
    
    def _determine_trend_direction(self, forecast_points: List[Dict]) -> str:
        """Determine if trend is going up, down, or staying stable."""
        if not forecast_points or len(forecast_points) < 2:
            return "stable"
        
        # Compare first and last forecast points
        first_value = forecast_points[0]["predicted_mentions"]
        last_value = forecast_points[-1]["predicted_mentions"]
        
        change_percent = (last_value - first_value) / first_value if first_value > 0 else 0
        
        if change_percent > 0.2:
            return "up"
        elif change_percent < -0.2:
            return "down"
        else:
            return "stable"
    
    def _calculate_forecast_confidence(self, forecast: pd.DataFrame) -> float:
        """Calculate confidence in forecast."""
        # Confidence based on prediction interval width
        forecast["interval_width"] = forecast["yhat_upper"] - forecast["yhat_lower"]
        forecast["relative_width"] = forecast["interval_width"] / (forecast["yhat"] + 1)
        
        # Average relative width
        avg_width = forecast["relative_width"].mean()
        
        # Convert to confidence (lower width = higher confidence)
        confidence = max(0, 1.0 - avg_width)
        
        return min(confidence, 1.0)
    
    def _simple_forecast(self, detection_id: int, historical_data: List[Dict]) -> Dict:
        """Simple forecast when not enough data."""
        if not historical_data:
            return {
                "detection_id": detection_id,
                "forecast_points": [],
                "trend_direction": "stable",
                "confidence": 0.0
            }
        
        # Use average of recent data
        avg_mentions = np.mean([d.get("mentions", 0) for d in historical_data])
        
        # Generate simple forecast
        forecast_points = []
        for i in range(182):
            date = datetime.utcnow() + timedelta(days=i)
            forecast_points.append({
                "date": date.isoformat(),
                "predicted_mentions": int(avg_mentions),
                "lower_bound": int(avg_mentions * 0.8),
                "upper_bound": int(avg_mentions * 1.2)
            })
        
        return {
            "detection_id": detection_id,
            "forecast_points": forecast_points,
            "trend_direction": "stable",
            "confidence": 0.3  # Low confidence for simple forecast
        }

