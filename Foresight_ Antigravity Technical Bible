# backend/app/services/mirofish_integration.py
from typing import Dict, List
import json
from datetime import datetime, timedelta

class MiroFishSimulator:
    def __init__(self):
        self.agents = {}
        self.communities = self._initialize_communities()
    
    def _initialize_communities(self) -> Dict:
        """Initialize communities with different characteristics."""
        return {
            "reddit_tech": {
                "name": "r/Technology",
                "platform": "reddit",
                "size": 5000000,
                "influence": 0.8,
                "adoption_rate": 0.3
            },
            "twitter_tech": {
                "name": "Twitter Tech",
                "platform": "twitter",
                "size": 2000000,
                "influence": 0.9,
                "adoption_rate": 0.4
            },
            "discord_dev": {
                "name": "Discord Dev Communities",
                "platform": "discord",
                "size": 500000,
                "influence": 0.7,
                "adoption_rate": 0.5
            },
            "hackernews": {
                "name": "Hacker News",
                "platform": "hackernews",
                "size": 1000000,
                "influence": 0.95,
                "adoption_rate": 0.2
            },
            "mainstream_media": {
                "name": "Mainstream Media",
                "platform": "news",
                "size": 100000000,
                "influence": 1.0,
                "adoption_rate": 0.1
            }
        }
    
    def simulate_trend_spread(
        self,
        trend_topic: str,
        initial_confidence: float,
        initial_platforms: List[str],
        weeks: int = 26
    ) -> Dict:
        """
        Simulate how a trend spreads across communities.
        
        Returns:
        {
            "trend": str,
            "simulation_data": [
                {
                    "week": int,
                    "community": str,
                    "adoption_rate": float,
                    "total_mentions": int,
                    "virality": float
                }
            ],
            "spread_path": [
                {
                    "order": int,
                    "community": str,
                    "time_to_adoption": int  # hours
                }
            ],
            "virality_coefficient": float,
            "decay_probability": float,
            "mainstream_eta": str  # ISO datetime
        }
        """
        simulation_data = []
        spread_path = []
        
        # Initialize agent states
        agent_states = {
            community: {
                "adoption": 0.0,
                "mentions": 0,
                "influenced_by": []
            }
            for community in self.communities.keys()
        }
        
        # Start with initial platforms
        for platform in initial_platforms:
            for community_id, community in self.communities.items():
                if community["platform"] == platform:
                    agent_states[community_id]["adoption"] = initial_confidence
        
        # Simulate week by week
        adoption_order = []
        for week in range(weeks):
            week_data = []
            
            for community_id, community in self.communities.items():
                state = agent_states[community_id]
                
                # Calculate adoption based on influences
                base_adoption = state["adoption"]
                influenced_adoption = sum(
                    agent_states[influenced]["adoption"] * 0.1
                    for influenced in state["influenced_by"]
                )
                
                # Update adoption
                new_adoption = min(
                    1.0,
                    base_adoption + influenced_adoption +
                    (community["adoption_rate"] * 0.05)
                )
                
                # Calculate mentions
                mentions = int(new_adoption * community["size"] * 0.01)
                
                # Track first adoption
                if base_adoption == 0 and new_adoption > 0.1:
                    adoption_order.append({
                        "order": len(adoption_order) + 1,
                        "community": community_id,
                        "time_to_adoption": week * 7 * 24  # Convert weeks to hours
                    })
                
                state["adoption"] = new_adoption
                state["mentions"] = mentions
                
                week_data.append({
                    "week": week,
                    "community": community_id,
                    "adoption_rate": new_adoption,
                    "total_mentions": mentions,
                    "virality": self._calculate_virality(agent_states)
                })
            
            simulation_data.extend(week_data)
            
            # Update influences (communities influence each other)
            self._update_influences(agent_states)
        
        # Calculate metrics
        virality_coefficient = self._calculate_virality_coefficient(agent_states)
        decay_probability = self._calculate_decay_probability(simulation_data)
        mainstream_eta = self._estimate_mainstream_eta(simulation_data)
        
        return {
            "trend": trend_topic,
            "simulation_data": simulation_data,
            "spread_path": adoption_order,
            "virality_coefficient": virality_coefficient,
            "decay_probability": decay_probability,
            "mainstream_eta": mainstream_eta,
            "generated_at": datetime.utcnow().isoformat()
        }
    
    def _calculate_virality(self, agent_states: Dict) -> float:
        """Calculate current virality score."""
        total_adoption = sum(
            state["adoption"]
            for state in agent_states.values()
        )
        return min(1.0, total_adoption / len(agent_states))
    
    def _update_influences(self, agent_states: Dict):
        """Update which communities influence each other."""
        # Communities with high adoption influence others
        high_adoption = [
            (community_id, state["adoption"])
            for community_id, state in agent_states.items()
            if state["adoption"] > 0.3
        ]
        
        for community_id, state in agent_states.items():
            state["influenced_by"] = [
                comm_id for comm_id, adoption in high_adoption
                if comm_id != community_id
            ]
    
    def _calculate_virality_coefficient(self, agent_states: Dict) -> float:
        """
        Calculate virality coefficient.
        
        Measures how many new people each infected person infects.
        > 1.0 = exponential growth
        = 1.0 = stable
        < 1.0 = decay
        """
        # Simplified: based on adoption spread
        adoptions = [state["adoption"] for state in agent_states.values()]
        if not adoptions or adoptions[0] == 0:
            return 1.0
        
        growth_rate = adoptions[-1] / (adoptions[0] + 0.001)
        return min(growth_rate, 5.0)  # Cap at 5.0
    
    def _calculate_decay_probability(self, simulation_data: List[Dict]) -> float:
        """
        Calculate probability that trend will decay.
        
        Based on trend momentum and saturation.
        """
        if not simulation_data:
            return 0.5
        
        # Get last week's virality
        last_week_data = [d for d in simulation_data if d["week"] == max(d["week"] for d in simulation_data)]
        avg_virality = sum(d["virality"] for d in last_week_data) / len(last_week_data)
        
        # High virality = low decay probability
        decay_prob = 1.0 - avg_virality
        
        return max(0.0, min(1.0, decay_prob))
    
    def _estimate_mainstream_eta(self, simulation_data: List[Dict]) -> str:
        """Estimate when trend will reach mainstream media."""
        # Find when mainstream_media adoption exceeds 0.5
        for data in simulation_data:
            if data["community"] == "mainstream_media" and data["adoption_rate"] > 0.5:
                weeks_to_mainstream = data["week"]
                eta = datetime.utcnow() + timedelta(weeks=weeks_to_mainstream)
                return eta.isoformat()
        
        # If not reached, estimate based on trend
        return (datetime.utcnow() + timedelta(weeks=26)).isoformat()

# Usage
mirofish_simulator = MiroFishSimulator()

@app.post("/simulate/{detection_id}")
async def simulate_trend(detection_id: int, user_id: int = Depends(verify_token)):
    """Run MiroFish simulation for a trend."""
    detection = db.query(Detection).filter(Detection.id == detection_id).first()
    
    if not detection:
        raise HTTPException(status_code=404, detail="Detection not found")
    
    # Run simulation
    simulation = mirofish_simulator.simulate_trend_spread(
        trend_topic=detection.topic,
        initial_confidence=detection.confidence,
        initial_platforms=detection.platforms,
        weeks=26
    )
    
    # Store simulation
    db_simulation = Simulation(
        detection_id=detection_id,
        simulation_data=simulation["simulation_data"],
        spread_path=simulation["spread_path"],
        virality_coefficient=simulation["virality_coefficient"],
        decay_probability=simulation["decay_probability"],
        mainstream_eta=simulation["mainstream_eta"]
    )
    db.add(db_simulation)
    db.commit()
    
    return simulation
