# backend/app/api/signals.py
from fastapi import APIRouter, HTTPException, Depends, BackgroundTasks
from pydantic import BaseModel
from typing import List
import redis

router = APIRouter(prefix="/signals", tags=["signals"])
redis_client = redis.Redis(host='localhost', port=6379, db=0)

class SignalInput(BaseModel):
    text: str
    platform: str  # twitter, reddit, discord, etc
    author: str
    url: str
    metadata: dict = {}

class SignalResponse(BaseModel):
    id: int
    text: str
    platform: str
    created_at: str

@router.post("/ingest", response_model=SignalResponse)
async def ingest_signal(
    signal: SignalInput,
    background_tasks: BackgroundTasks,
    user_id: int = Depends(verify_token)
):
    """
    Ingest a signal from external source.
    
    Rate limit: 1000 signals per minute per user
    """
    # Check rate limit
    rate_limit_key = f"signal_ingest:{user_id}"
    current_count = redis_client.incr(rate_limit_key)
    if current_count == 1:
        redis_client.expire(rate_limit_key, 60)
    
    if current_count > 1000:
        raise HTTPException(status_code=429, detail="Rate limit exceeded")
    
    # Validate signal
    if len(signal.text) < 10 or len(signal.text) > 2000:
        raise HTTPException(status_code=400, detail="Signal text must be 10-2000 characters")
    
    # Store in database
    db_signal = Signal(
        text=signal.text,
        platform=signal.platform,
        author=signal.author,
        url=signal.url,
        metadata=signal.metadata
    )
    db.add(db_signal)
    db.commit()
    db.refresh(db_signal)
    
    # Queue for processing
    background_tasks.add_task(process_signal, db_signal.id)
    
    return SignalResponse(
        id=db_signal.id,
        text=db_signal.text,
        platform=db_signal.platform,
        created_at=db_signal.created_at.isoformat()
    )

@router.get("/", response_model=List[SignalResponse])
async def list_signals(
    limit: int = 100,
    offset: int = 0,
    platform: str = None,
    user_id: int = Depends(verify_token)
):
    """List signals with optional filtering."""
    query = db.query(Signal)
    
    if platform:
        query = query.filter(Signal.platform == platform)
    
    signals = query.order_by(Signal.created_at.desc()).limit(limit).offset(offset).all()
    
    return [
        SignalResponse(
            id=s.id,
            text=s.text,
            platform=s.platform,
            created_at=s.created_at.isoformat()
        )
        for s in signals
    ]

