# backend/app/services/search_engine.py
from elasticsearch import Elasticsearch
from typing import List, Dict

es = Elasticsearch(['localhost:9200'])

class SearchEngine:
    def __init__(self):
        self.index_name = "foresight_signals"
        self._create_index()
    
    def _create_index(self):
        """Create Elasticsearch index with proper mappings."""
        if not es.indices.exists(index=self.index_name):
            es.indices.create(
                index=self.index_name,
                body={
                    "settings": {
                        "number_of_shards": 1,
                        "number_of_replicas": 0,
                        "analysis": {
                            "analyzer": {
                                "default": {
                                    "type": "standard",
                                    "stopwords": "_english_"
                                }
                            }
                        }
                    },
                    "mappings": {
                        "properties": {
                            "text": {"type": "text"},
                            "platform": {"type": "keyword"},
                            "author": {"type": "keyword"},
                            "keywords": {"type": "keyword"},
                            "entities": {"type": "keyword"},
                            "sentiment": {"type": "keyword"},
                            "category": {"type": "keyword"},
                            "created_at": {"type": "date"},
                            "confidence": {"type": "float"}
                        }
                    }
                }
            )
    
    def index_signal(self, signal: Dict):
        """Index a signal in Elasticsearch."""
        es.index(
            index=self.index_name,
            id=signal["id"],
            body={
                "text": signal["text"],
                "platform": signal["platform"],
                "author": signal.get("author"),
                "keywords": signal.get("keywords", []),
                "entities": signal.get("entities", []),
                "sentiment": signal.get("sentiment"),
                "category": signal.get("category"),
                "created_at": signal["created_at"],
                "confidence": signal.get("confidence", 0)
            }
        )
    
    def search(
        self,
        query: str,
        filters: Dict = None,
        limit: int = 20,
        offset: int = 0
    ) -> Dict:
        """
        Search signals.
        
        Returns:
        {
            "total": int,
            "results": [
                {
                    "id": int,
                    "text": str,
                    "platform": str,
                    "score": float,
                    "highlight": str
                }
            ],
            "facets": {
                "platforms": {...},
                "sentiments": {...},
                "categories": {...}
            }
        }
        """
        # Build query
        es_query = {
            "bool": {
                "must": [
                    {
                        "multi_match": {
                            "query": query,
                            "fields": ["text", "keywords", "entities"],
                            "fuzziness": "AUTO"
                        }
                    }
                ]
            }
        }
        
        # Add filters
        if filters:
            if "platform" in filters:
                es_query["bool"]["filter"] = [
                    {"term": {"platform": filters["platform"]}}
                ]
            if "sentiment" in filters:
                if "filter" not in es_query["bool"]:
                    es_query["bool"]["filter"] = []
                es_query["bool"]["filter"].append(
                    {"term": {"sentiment": filters["sentiment"]}}
                )
        
        # Execute search
        response = es.search(
            index=self.index_name,
            body={
                "query": es_query,
                "from": offset,
                "size": limit,
                "highlight": {
                    "fields": {
                        "text": {},
                        "keywords": {}
                    }
                },
                "aggs": {
                    "platforms": {
                        "terms": {"field": "platform", "size": 10}
                    },
                    "sentiments": {
                        "terms": {"field": "sentiment", "size": 10}
                    },
                    "categories": {
                        "terms": {"field": "category", "size": 10}
                    }
                }
            }
        )
        
        # Format results
        results = []
        for hit in response["hits"]["hits"]:
            results.append({
                "id": hit["_id"],
                "text": hit["_source"]["text"],
                "platform": hit["_source"]["platform"],
                "score": hit["_score"],
                "highlight": hit.get("highlight", {}).get("text", [""])[0]
            })
        
        # Format facets
        facets = {
            "platforms": {
                bucket["key"]: bucket["doc_count"]
                for bucket in response["aggregations"]["platforms"]["buckets"]
            },
            "sentiments": {
                bucket["key"]: bucket["doc_count"]
                for bucket in response["aggregations"]["sentiments"]["buckets"]
            },
            "categories": {
                bucket["key"]: bucket["doc_count"]
                for bucket in response["aggregations"]["categories"]["buckets"]
            }
        }
        
        return {
            "total": response["hits"]["total"]["value"],
            "results": results,
            "facets": facets
        }
    
    def autocomplete(self, prefix: str, field: str = "keywords") -> List[str]:
        """Get autocomplete suggestions."""
        response = es.search(
            index=self.index_name,
            body={
                "aggs": {
                    "suggestions": {
                        "terms": {
                            "field": field,
                            "prefix": prefix,
                            "size": 10
                        }
                    }
                }
            }
        )
        
        return [
            bucket["key"]
            for bucket in response["aggregations"]["suggestions"]["buckets"]
        ]

# Usage
