# backend/app/services/nlp_processor.py
import spacy
from typing import List, Dict
import hashlib
from datetime import datetime, timedelta

nlp = spacy.load("en_core_web_sm")

class SignalProcessor:
    def __init__(self):
        self.processed_signals = {}
        self.deduplication_window = timedelta(hours=1)
    
    def process_signal(self, text: str, platform: str) -> Dict:
        """
        Process a signal through NLP pipeline.
        
        Returns:
        {
            "text": str,
            "entities": List[str],
            "keywords": List[str],
            "sentiment": str,  # positive, negative, neutral
            "category": str,
            "normalized_text": str,
            "hash": str
        }
        """
        # Normalize text
        normalized = self._normalize_text(text)
        
        # Check for duplicates
        signal_hash = hashlib.md5(normalized.encode()).hexdigest()
        if self._is_duplicate(signal_hash):
            return None
        
        # Process with spaCy
        doc = nlp(normalized)
        
        # Extract entities
        entities = [ent.text for ent in doc.ents]
        
        # Extract keywords (nouns and proper nouns)
        keywords = [token.text for token in doc if token.pos_ in ["NOUN", "PROPN"]]
        
        # Classify sentiment (simple heuristic)
        sentiment = self._classify_sentiment(text)
        
        # Classify category
        category = self._classify_category(keywords, entities)
        
        return {
            "text": text,
            "normalized_text": normalized,
            "entities": list(set(entities)),
            "keywords": list(set(keywords)),
            "sentiment": sentiment,
            "category": category,
            "hash": signal_hash,
            "platform": platform
        }
    
    def _normalize_text(self, text: str) -> str:
        """Normalize text for processing."""
        # Remove URLs
        text = re.sub(r'http\S+|www\S+', '', text)
        # Remove mentions
        text = re.sub(r'@\w+', '', text)
        # Remove hashtags (keep text)
        text = re.sub(r'#(\w+)', r'\1', text)
        # Convert to lowercase
        text = text.lower()
        # Remove extra whitespace
        text = ' '.join(text.split())
        return text
    
    def _is_duplicate(self, signal_hash: str) -> bool:
        """Check if signal is duplicate."""
        if signal_hash in self.processed_signals:
            last_seen = self.processed_signals[signal_hash]
            if datetime.utcnow() - last_seen < self.deduplication_window:
                return True
        self.processed_signals[signal_hash] = datetime.utcnow()
        return False
    
    def _classify_sentiment(self, text: str) -> str:
        """Classify sentiment of text."""
        # Simple heuristic (can be replaced with ML model)
        positive_words = ['good', 'great', 'awesome', 'amazing', 'love', 'best']
        negative_words = ['bad', 'terrible', 'awful', 'hate', 'worst', 'sucks']
        
        text_lower = text.lower()
        positive_count = sum(1 for word in positive_words if word in text_lower)
        negative_count = sum(1 for word in negative_words if word in text_lower)
        
        if positive_count > negative_count:
            return "positive"
        elif negative_count > positive_count:
            return "negative"
        else:
            return "neutral"
    
    def _classify_category(self, keywords: List[str], entities: List[str]) -> str:
        """Classify signal category."""
        # Simple category classification based on keywords
        categories = {
            "technology": ["ai", "tech", "software", "code", "app", "algorithm"],
            "finance": ["stock", "crypto", "bitcoin", "ethereum", "market", "trading"],
            "health": ["health", "medical", "disease", "vaccine", "covid", "wellness"],
            "business": ["startup", "business", "company", "entrepreneur", "ipo"],
            "entertainment": ["movie", "music", "celebrity", "entertainment", "show"]
        }
        
        all_words = keywords + entities
        all_words_lower = [w.lower() for w in all_words]
        
        for category, keywords_list in categories.items():
            if any(keyword in all_words_lower for keyword in keywords_list):
                return category
        
        return "other"

# Usage
