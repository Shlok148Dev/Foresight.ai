#### Step 5.2: Trend Detection Algorithm

**Specification:**
- Detect emerging trends from processed signals
- Calculate confidence scores
- Identify trend stage (embryonic, emerging, accelerating, peaking, declining)
- Track velocity (signals per hour)
- Group related signals by topic

**Implementation Details:**

```python
# backend/app/services/detection_engine.py
from typing import List, Dict
from datetime import datetime, timedelta
from collections import defaultdict
import numpy as np

class TrendDetectionEngine:
    def __init__(self):
        self.trend_cache = {}
        self.signal_history = defaultdict(list)
        self.min_confidence = 0.6
        self.min_signals = 5
    
    def detect_trends(self, signals: List[Dict]) -> List[Dict]:
        """
        Detect trends from signals.
        
        Returns:
        [
            {
                "topic": str,
                "stage": str,  # embryonic, emerging, accelerating, peaking, declining
                "confidence": float,  # 0-1
                "signal_count": int,
                "velocity": float,  # signals per hour
                "platforms": List[str],
                "keywords": List[str],
                "entities": List[str]
            }
        ]
        """
        # Group signals by topic
        topics = self._group_signals_by_topic(signals)
        
        # Detect trends
        trends = []
        for topic, topic_signals in topics.items():
            if len(topic_signals) >= self.min_signals:
                trend = self._analyze_trend(topic, topic_signals)
                if trend["confidence"] >= self.min_confidence:
                    trends.append(trend)
        
        return sorted(trends, key=lambda x: x["confidence"], reverse=True)
    
    def _group_signals_by_topic(self, signals: List[Dict]) -> Dict[str, List[Dict]]:
        """Group signals by topic using keywords."""
        topics = defaultdict(list)
        
        for signal in signals:
            # Use keywords and entities as topic identifiers
            keywords = signal.get("keywords", [])
            entities = signal.get("entities", [])
            
            # Create topic key from top keywords/entities
            topic_key = self._create_topic_key(keywords, entities)
            
            if topic_key:
                topics[topic_key].append(signal)
        
        return topics
    
    def _create_topic_key(self, keywords: List[str], entities: List[str]) -> str:
        """Create a topic key from keywords and entities."""
        # Combine and deduplicate
        all_terms = list(set(keywords + entities))
        
        if not all_terms:
            return None
        
        # Sort for consistency
        all_terms.sort()
        
        # Create key from top 3 terms
        topic_key = " ".join(all_terms[:3])
        
        return topic_key
    
    def _analyze_trend(self, topic: str, signals: List[Dict]) -> Dict:
        """Analyze a trend."""
        # Calculate confidence
        confidence = self._calculate_confidence(signals)
        
        # Determine stage
        stage = self._determine_stage(topic, signals)
        
        # Calculate velocity
        velocity = self._calculate_velocity(signals)
        
        # Extract platforms
        platforms = list(set([s.get("platform") for s in signals]))
        
        # Extract keywords and entities
        all_keywords = []
        all_entities = []
        for signal in signals:
            all_keywords.extend(signal.get("keywords", []))
            all_entities.extend(signal.get("entities", []))
        
        keywords = list(set(all_keywords))[:10]
        entities = list(set(all_entities))[:10]
        
        return {
            "topic": topic,
            "stage": stage,
            "confidence": confidence,
            "signal_count": len(signals),
            "velocity": velocity,
            "platforms": platforms,
            "keywords": keywords,
            "entities": entities,
            "detected_at": datetime.utcnow().isoformat()
        }
    
    def _calculate_confidence(self, signals: List[Dict]) -> float:
        """
        Calculate confidence score for trend.
        
        Factors:
        - Number of signals
        - Diversity of platforms
        - Sentiment consistency
        - Recency
        """
        # Base confidence from signal count
        signal_count_score = min(len(signals) / 100, 1.0)  # Max 100 signals
        
        # Platform diversity
        platforms = set([s.get("platform") for s in signals])
        platform_score = len(platforms) / 5  # Max 5 platforms
        
        # Sentiment consistency
        sentiments = [s.get("sentiment") for s in signals]
        sentiment_score = 1.0 - (len(set(sentiments)) / 3)  # Less diversity = higher score
        
        # Recency (recent signals are more important)
        now = datetime.utcnow()
        recency_scores = []
        for signal in signals:
            age_hours = (now - signal.get("created_at")).total_seconds() / 3600
            recency_score = max(0, 1.0 - (age_hours / 24))  # Decay over 24 hours
            recency_scores.append(recency_score)
        
        recency_score = np.mean(recency_scores) if recency_scores else 0
        
        # Weighted average
        confidence = (
            signal_count_score * 0.4 +
            platform_score * 0.3 +
            sentiment_score * 0.15 +
            recency_score * 0.15
        )
        
        return min(confidence, 1.0)
    
    def _determine_stage(self, topic: str, signals: List[Dict]) -> str:
        """Determine trend stage based on velocity and history."""
        # Get historical data for this topic
        history = self.signal_history[topic]
        
        # Calculate current velocity
        now = datetime.utcnow()
        recent_signals = [s for s in signals if (now - s.get("created_at")).total_seconds() < 3600]
        current_velocity = len(recent_signals)
        
        # Determine stage based on velocity trend
        if len(history) == 0:
            stage = "embryonic"
        elif current_velocity < 5:
            stage = "embryonic"
        elif current_velocity < 20:
            stage = "emerging"
        elif current_velocity < 50:
            stage = "accelerating"
        elif current_velocity < 100:
            stage = "peaking"
        else:
            stage = "declining"
        
        # Update history
        self.signal_history[topic].append({
            "velocity": current_velocity,
            "timestamp": now
        })
        
        return stage
    
    def _calculate_velocity(self, signals: List[Dict]) -> float:
        """Calculate signals per hour."""
        if not signals:
            return 0.0
        
        # Get time range
        timestamps = [s.get("created_at") for s in signals]
        min_time = min(timestamps)
        max_time = max(timestamps)
        
        time_diff = (max_time - min_time).total_seconds() / 3600  # Convert to hours
        
        if time_diff == 0:
            return float(len(signals))
        
        return len(signals) / time_diff

# Usage
